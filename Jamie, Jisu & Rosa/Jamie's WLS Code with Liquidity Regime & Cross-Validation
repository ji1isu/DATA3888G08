# DATA LOADING HELPER
# Call this at the top of any analysis script to get the
# correctly filtered, renamed, sorted dataframe.
# ─────────────────────────────────────────────────────────────────────
def load_filtered_dataset(csv_path: str,
                          stocks: list = None,
                          verbose: bool = True) -> pd.DataFrame:
    """
    Load optiver_aggregated.csv and apply all shared filters:
      1. Drop time_bucket == 0
      2. Rename columns to match WLS pipeline conventions
      3. Filter to SAMPLED_TIME_IDS (the 300 sampled time_ids)
      4. Optionally filter to a specific stock list (default: DEMO_STOCKS)
      5. Sort by stock_id, time_id, time_bucket

    Parameters
    ----------
    csv_path : str
        Path to optiver_aggregated.csv
    stocks : list of int, optional
        Stock IDs to keep. Defaults to DEMO_STOCKS (all 60 demo stocks).
        Pass None to keep all 112 stocks (Phase 2 style).
    verbose : bool
        Print row/shape info if True.

    Returns
    -------
    pd.DataFrame with columns: stock_id, time_id, time_bucket, wap, bas, rv
    """
    df = pd.read_csv(csv_path)
    df = df[df["time_bucket"] > 0].copy()
    df = df.rename(columns={
        "WAP_mean":         "wap",
        "BidAskSpread_mean": "bas",
        "volatility":        "rv",
    })
    df = df[df["time_id"].isin(SAMPLED_TIME_IDS)].copy()

    if stocks is not None:
        df = df[df["stock_id"].isin(stocks)].copy()

    df = df.sort_values(["stock_id", "time_id", "time_bucket"]).reset_index(drop=True)

    if verbose:
        print(f"  Loaded: {df.shape[0]:,} rows  |  "
              f"{df['stock_id'].nunique()} stocks  |  "
              f"{df['time_id'].nunique()} time_ids")

    return df


# ─────────────────────────────────────────────────────────────────────
# SPLIT HELPERS
# ─────────────────────────────────────────────────────────────────────
def get_holdout_split(df: pd.DataFrame):
    """
    Apply the shared 80/20 holdout split.

    Train : time_bucket in TRAIN_BUCKETS (1–16)
    Test  : time_bucket in TEST_BUCKETS  (17–20)

    Returns
    -------
    train_df, test_df
    """
    train = df[df["time_bucket"].isin(TRAIN_BUCKETS)].copy()
    test  = df[df["time_bucket"].isin(TEST_BUCKETS)].copy()
    return train, test


def get_cv_folds(df: pd.DataFrame):
    """
    Yield the 5 shared CV folds from CV_FOLDS.

    Each fold yields (fold_num, train_df, val_df) where
    train and val are subsets of the HOLDOUT TRAIN set only
    (time_bucket 1–16). The holdout test set (17–20) is never
    touched during CV.

    Usage
    -----
        for fold_num, tr, val in get_cv_folds(train_df):
            # fit on tr, evaluate on val
    """
    for fold_num, tr_buckets, val_buckets in CV_FOLDS:
        tr  = df[df["time_bucket"].isin(tr_buckets)].copy()
        val = df[df["time_bucket"].isin(val_buckets)].copy()
        yield fold_num, tr, val


def get_regime_stocks(regime: str) -> list:
    """
    Return the list of demo stock_ids for a given regime.

    Parameters
    ----------
    regime : str  — one of 'liquid', 'mixed', 'illiquid'
    """
    mapping = {
        "liquid":   LIQUID_STOCKS,
        "mixed":    MIXED_STOCKS,
        "illiquid": ILLIQUID_STOCKS,
    }
    if regime not in mapping:
        raise ValueError(f"regime must be one of {list(mapping.keys())}, got '{regime}'")
    return mapping[regime]


