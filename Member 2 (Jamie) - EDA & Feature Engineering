# 12. ALPHA TUNING — PARALLEL GRID SEARCH

print("\n" + "=" * 60)
print("ALPHA TUNING (WLS decay parameter)")
print("=" * 60)
 
alpha_grid = np.round(np.arange(0.05, 1.00, 0.01), 3)
 
def fit_alpha(a, X_train, y_train, X_test, y_test, n_train, bucket_vals):
    weights = a ** (n_train - bucket_vals)
    wls     = LinearRegression().fit(X_train, y_train, sample_weight=weights)
    preds   = np.maximum(wls.predict(X_test), 1e-8)
    return {
        "alpha": a,
        "qlike": qlike(y_test, preds),
        "mse":   mse(y_test, preds),
        "mae":   mae(y_test, preds),
    }
 
tune_results = Parallel(n_jobs=-1, verbose=0)(
    delayed(fit_alpha)(a, X_train, y_train, X_test, y_test, n_train, bucket_vals)
    for a in alpha_grid
)
tune_df    = pd.DataFrame(tune_results)
best_row   = tune_df.loc[tune_df["qlike"].idxmin()]
best_alpha = best_row["alpha"]
print(f"Best alpha: {best_alpha:.2f}  |  Validation QLIKE: {best_row['qlike']:.6f}")
 
# Alpha tuning plot
fig, axes = plt.subplots(1, 3, figsize=(20, 5))
fig.suptitle("Alpha Tuning: WLS Decay Parameter Grid Search", fontsize=14, fontweight="bold")
 
for ax, metric in zip(axes, ["qlike", "mse", "mae"]):
    ax.plot(tune_df["alpha"], tune_df[metric], color="steelblue", linewidth=1.5)
    best_val = tune_df.loc[tune_df["qlike"].idxmin(), metric]
    ax.axvline(best_alpha, color="red", linestyle="--", linewidth=1.2,
               label=f"Best α={best_alpha:.2f} ({metric.upper()}={best_val:.6f})")
    ax.set_title(f"{metric.upper()} vs Alpha")
    ax.set_xlabel("Alpha"); ax.set_ylabel(metric.upper())
    ax.legend(fontsize=8)
 
plt.tight_layout()
