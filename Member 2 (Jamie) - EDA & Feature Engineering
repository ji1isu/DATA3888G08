# 10. LOSS FUNCTIONS

def qlike(y, yhat):
    """QLIKE loss — standard volatility forecasting criterion."""
    yhat = np.maximum(yhat, 1e-8)
    return np.mean(np.log(yhat) + y / yhat)
 
def mse(y, yhat):
    return np.mean((y - yhat) ** 2)
 
def mae(y, yhat):
    return np.mean(np.abs(y - yhat))
 

