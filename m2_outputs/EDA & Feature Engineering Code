print("  ─────────────────────────────────────────────────────────────")
print("  w(t) = α^(T − t)")
print()
print("  where  t = time_bucket index of observation (1 … T)")
print("         T = last training bucket")
print("         α ∈ (0, 1] = decay parameter")
print()
print("  Interpretation for traders:")
print("  ─────────────────────────────────────────────────────────────")
print("  OLS treats a 30-second window from 3 hours ago identically")
print("  to a window from 30 seconds ago.  For intra-day vol that is")
print("  wrong — market conditions shift.  WLS fixes this by assigning")
print("  exponentially higher weight to more recent buckets.")
print("  α = 0.99 → gentle decay (long memory)")
print("  α = 0.80 → fast decay  (only the last few minutes matter)")
print("  We select α by minimising out-of-sample QLIKE on the val set.")
print("=" * 70)

alpha_grid = np.round(np.arange(0.05, 1.00, 0.01), 3)

def fit_alpha(a, X_train, y_train, X_test, y_test, T, bucket_vals):
    w    = a ** (T - bucket_vals)
    wls  = LinearRegression().fit(X_train, y_train, sample_weight=w)
    pred = np.maximum(wls.predict(X_test), 1e-8)
    return {
        "alpha": a,
        "qlike": qlike(y_test, pred),
        "mse":   mse(y_test, pred),
        "mae":   mae(y_test, pred),
    }

